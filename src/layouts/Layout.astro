---
import { ClientRouter, ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Daniel Calin Stanus - Full Stack Developer Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter client:load />
    <!-- <ViewTransitions /> -->
  </head>
  <body>
    <slot />
    <script>
      // Check for saved theme preference
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('darkMode')) {
          return localStorage.getItem('darkMode') === 'true' ? 'dark' : 'light';
        }
        return 'light'; // default theme
      })();
      
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </body>
</html>